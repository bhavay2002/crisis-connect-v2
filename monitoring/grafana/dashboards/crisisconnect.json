{
  "__inputs": [],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" }
  ],
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "title": "API Health",
      "type": "row",
      "id": 1
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          },
          "mappings": [
            { "options": { "0": { "text": "DOWN" }, "1": { "text": "UP" } }, "type": "value" }
          ]
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 },
      "options": { "colorMode": "background", "graphMode": "none", "textMode": "value" },
      "targets": [{ "expr": "up{job=\"crisisconnect-api\"}", "legendFormat": "API" }],
      "title": "API Status",
      "type": "stat",
      "id": 2
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "unit": "reqps",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 100 },
              { "color": "red", "value": 500 }
            ]
          }
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 1 },
      "options": { "colorMode": "value", "graphMode": "area", "textMode": "auto" },
      "targets": [{ "expr": "sum(rate(http_requests_total{job=\"crisisconnect-api\"}[5m]))", "legendFormat": "RPS" }],
      "title": "Request Rate",
      "type": "stat",
      "id": 3
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.01 },
              { "color": "red", "value": 0.05 }
            ]
          }
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 1 },
      "options": { "colorMode": "background", "graphMode": "area", "textMode": "auto" },
      "targets": [{
        "expr": "sum(rate(http_requests_total{job=\"crisisconnect-api\",status=~\"5..\"}[5m])) / sum(rate(http_requests_total{job=\"crisisconnect-api\"}[5m]))",
        "legendFormat": "Error Rate"
      }],
      "title": "Error Rate (5xx)",
      "type": "stat",
      "id": 4
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.5 },
              { "color": "red", "value": 2 }
            ]
          }
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 1 },
      "options": { "colorMode": "value", "graphMode": "area", "textMode": "auto" },
      "targets": [{
        "expr": "histogram_quantile(0.95, rate(http_request_duration_seconds_bucket{job=\"crisisconnect-api\"}[5m]))",
        "legendFormat": "p95"
      }],
      "title": "Latency p95",
      "type": "stat",
      "id": 5
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "red", "value": 90 }
            ]
          }
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 1 },
      "options": { "colorMode": "background", "graphMode": "area", "textMode": "auto" },
      "targets": [{ "expr": "crisis_queue_size", "legendFormat": "Queue Depth" }],
      "title": "Job Queue Depth",
      "type": "stat",
      "id": 6
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "short" }
      },
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 1 },
      "options": { "colorMode": "value", "graphMode": "area", "textMode": "auto" },
      "targets": [{ "expr": "crisis_ws_connections", "legendFormat": "WS Connections" }],
      "title": "WebSocket Connections",
      "type": "stat",
      "id": 7
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "title": "Request Throughput & Latency",
      "type": "row",
      "id": 10
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": { "unit": "reqps", "custom": { "lineWidth": 2 } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "2xx" }, "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "4xx" }, "properties": [{ "id": "color", "value": { "fixedColor": "yellow", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "5xx" }, "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }] }
        ]
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        { "expr": "sum(rate(http_requests_total{job=\"crisisconnect-api\",status=~\"2..\"}[5m]))", "legendFormat": "2xx" },
        { "expr": "sum(rate(http_requests_total{job=\"crisisconnect-api\",status=~\"4..\"}[5m]))", "legendFormat": "4xx" },
        { "expr": "sum(rate(http_requests_total{job=\"crisisconnect-api\",status=~\"5..\"}[5m]))", "legendFormat": "5xx" }
      ],
      "title": "Request Rate by Status",
      "type": "timeseries",
      "id": 11
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": { "unit": "s", "custom": { "lineWidth": 2 } }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "targets": [
        { "expr": "histogram_quantile(0.50, rate(http_request_duration_seconds_bucket{job=\"crisisconnect-api\"}[5m]))", "legendFormat": "p50" },
        { "expr": "histogram_quantile(0.95, rate(http_request_duration_seconds_bucket{job=\"crisisconnect-api\"}[5m]))", "legendFormat": "p95" },
        { "expr": "histogram_quantile(0.99, rate(http_request_duration_seconds_bucket{job=\"crisisconnect-api\"}[5m]))", "legendFormat": "p99" }
      ],
      "title": "Request Latency Percentiles",
      "type": "timeseries",
      "id": 12
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 },
      "title": "AI Pipeline & Queue",
      "type": "row",
      "id": 20
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": { "unit": "short", "custom": { "lineWidth": 2 } }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 15 },
      "targets": [
        { "expr": "crisis_queue_size", "legendFormat": "Queue Depth" },
        { "expr": "crisis_queue_shed_total", "legendFormat": "Shed Count (total)" }
      ],
      "title": "Job Queue Depth & Shedding",
      "type": "timeseries",
      "id": 21
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": { "unit": "s", "custom": { "lineWidth": 2 } }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 15 },
      "targets": [
        { "expr": "histogram_quantile(0.95, rate(crisis_ai_analysis_duration_seconds_bucket[5m]))", "legendFormat": "AI Analysis p95" },
        { "expr": "histogram_quantile(0.99, rate(crisis_ai_analysis_duration_seconds_bucket[5m]))", "legendFormat": "AI Analysis p99" }
      ],
      "title": "AI Analysis Duration",
      "type": "timeseries",
      "id": 22
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 23 },
      "title": "Infrastructure",
      "type": "row",
      "id": 30
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": { "unit": "percentunit", "custom": { "lineWidth": 2 },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 0.7 },
            { "color": "red", "value": 0.85 }
          ]}
        }
      },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 24 },
      "targets": [
        { "expr": "process_cpu_usage{job=\"crisisconnect-api\"}", "legendFormat": "API CPU" }
      ],
      "title": "Process CPU Usage",
      "type": "timeseries",
      "id": 31
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": { "unit": "bytes", "custom": { "lineWidth": 2 } }
      },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 24 },
      "targets": [
        { "expr": "process_resident_memory_bytes{job=\"crisisconnect-api\"}", "legendFormat": "API RSS" },
        { "expr": "nodejs_heap_size_used_bytes{job=\"crisisconnect-api\"}", "legendFormat": "Heap Used" }
      ],
      "title": "Memory Usage",
      "type": "timeseries",
      "id": 32
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": { "unit": "short", "custom": { "lineWidth": 2 } }
      },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 24 },
      "targets": [
        { "expr": "pg_stat_database_numbackends{datname=\"crisisconnect\"}", "legendFormat": "DB Connections" },
        { "expr": "redis_connected_clients", "legendFormat": "Redis Clients" }
      ],
      "title": "DB & Cache Connections",
      "type": "timeseries",
      "id": 33
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "tags": ["crisisconnect", "platform"],
  "templating": {
    "list": [
      {
        "current": {},
        "datasource": "Prometheus",
        "definition": "label_values(up{job=\"crisisconnect-api\"}, instance)",
        "hide": 0,
        "includeAll": true,
        "label": "Instance",
        "name": "instance",
        "options": [],
        "query": "label_values(up{job=\"crisisconnect-api\"}, instance)",
        "refresh": 2,
        "type": "query"
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "CrisisConnect Platform",
  "uid": "crisisconnect-main",
  "version": 1
}
